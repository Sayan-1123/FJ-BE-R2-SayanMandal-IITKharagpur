{
  "name": "personal-finance-tracker",
  "version": "1.0.0",
  "description": "AI-Powered Personal Finance Tracker",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage --forceExit --detectOpenHandles",
    "test:watch": "jest --watch --forceExit --detectOpenHandles",
    "setup-db": "node scripts/setup-db.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "setupFiles": ["./tests/setup.js"],
    "testTimeout": 30000
  },
  "keywords": ["finance", "tracker", "personal-finance", "budgeting"],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "express": "^4.21.0",
    "pg": "^8.13.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "dotenv": "^16.4.0",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^10.0.0",
    "csv-parser": "^3.0.0",
    "pdf-parse": "^1.1.1",
    "decimal.js": "^10.4.3",
    "nodemailer": "^6.9.0",
    "openai": "^4.60.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "cookie-parser": "^1.4.6",
    "express-session": "^1.18.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
